[Unit]
Description=PingFederate 12.3.6 DevOps Instance
Documentation=https://support.pingidentity.com/s/PingFederate-help

[Install]
WantedBy=multi-user.target

[Service]
Type=simple
User=pingusr

WorkingDirectory=/opt/install/pingfederate-12.3.6/pingfederate

Environment='JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64'

ExecStart=/opt/install/pingfederate-12.3.6/pingfederate/bin/run.sh

ExecStop=/opt/install/pingfederate-12.3.6/pingfederate/sbin/pingfederate-shutdown.sh

SuccessExitStatus=143

Restart=on-failure

RestartSec=10
